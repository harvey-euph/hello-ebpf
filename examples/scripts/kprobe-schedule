#! bin/bash
sudo bpftrace -e '
kprobe:schedule {
    printf("schedule() @ cpu=%d pid=%d comm=%s state=0x%x\n",
           cpu, pid, comm, ((struct task_struct*)bpf_get_current_task())->state);
}
'

